{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.py": {
      "excludeFiles": "{3D Web.0/**,**/__pycache__/**,**/*.pyc,**/*.mp4,**/*.png,**/*.jpg,**/*.jpeg,**/*.webp,**/*.gif}"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/3D Web.0/GDG/index.html" }
  ]
}

